generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  region    String
  telephone String?
  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("agent")
  createdAt DateTime @default(now())
}